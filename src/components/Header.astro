---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../consts";
---

<header>
  <nav>
    <!-- LOGO -->
    <h2><a href="/">{SITE_TITLE}</a></h2>

    <!-- MOBILE MENU BUTTON -->
    <button id="menu-toggle" aria-label="Toggle Menu"> ☰ </button>

    <!-- MENU -->
    <div class="internal-links" id="menu">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>

    <!-- THEME TOGGLE -->
    <div class="right-actions">
      <button id="theme-toggle" aria-label="Toggle theme" aria-pressed="false">
        <!-- Moon -->
        <svg
          class="icon moon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path d="M21 12.79A9 9 0 0111.21 3 7 7 0 1021 12.79z"></path>
        </svg>

        <!-- Sun -->
        <svg
          class="icon sun"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M12 4V2m0 20v-2m8-8h2M2 12h2
               m15.36 6.36l1.42 1.42
               M4.22 4.22l1.42 1.42
               m12.72-1.42l-1.42 1.42
               M6.64 17.36l-1.42 1.42
               M12 7a5 5 0 100 10
               5 5 0 000-10z"
          ></path>
        </svg>
      </button>
    </div>
  </nav>

  <script is:inline>
    const root = document.documentElement;
    const toggle = document.getElementById("theme-toggle");

    const savedTheme = localStorage.getItem("theme");
    const systemDark = window.matchMedia(
      "(prefers-color-scheme: dark)",
    ).matches;

    if (savedTheme === "dark" || (!savedTheme && systemDark)) {
      root.classList.add("dark");
    }

    if (toggle) {
      const updateState = () => {
        const isDark = root.classList.contains("dark");
        toggle.setAttribute("aria-pressed", isDark);
      };

      updateState();

      toggle.addEventListener("click", () => {
        root.classList.toggle("dark");
        const isDark = root.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
        updateState();
      });
    }

    /* MOBILE MENU */
    const menuToggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("menu");

    if (menuToggle && menu) {
      menuToggle.addEventListener("click", () => {
        menu.classList.toggle("open");
      });
    }
  </script>
</header>

<style>
  header {
    padding: 0 1.5em;
    background: var(--bg-main);
    border-bottom: 1px solid rgb(var(--border-color));
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* LOGO */

  h2 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
  }

  h2 a {
    color: rgb(var(--black));
    text-decoration: none;
  }

  /* MENU */

  .internal-links {
    display: flex;
    gap: 1.2rem;
  }

  nav a {
    padding: 1em 0.6em;
    color: rgb(var(--black));
    border-bottom: 3px solid transparent;
    text-decoration: none;
  }

  nav a:hover {
    color: var(--accent);
  }

  nav a.active {
    border-bottom-color: var(--accent);
    color: var(--accent);
  }

  /* RIGHT */

  .right-actions {
    display: flex;
    align-items: center;
  }

  /* THEME BUTTON */

  #theme-toggle {
    width: 2.5rem;
    height: 2.5rem;
    margin: 0.25rem 0.75rem;
    border-radius: 50%;
    border: 0.0625rem solid rgb(var(--border-color));
    background: var(--bg-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  #theme-toggle .icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .sun {
    display: none;
  }

  :root.dark .moon {
    display: none;
  }

  :root.dark .sun {
    display: block;
  }

  /* MOBILE MENU BUTTON */

  #menu-toggle {
    display: none;
    font-size: 1.6rem;
    background: none;
    border: none;
    cursor: pointer;
  }

  /* ---------- RESPONSIVE ---------- */

  @media (max-width: 900px) {
    .internal-links {
      gap: 0.8rem;
    }

    nav a {
      padding: 0.8em 0.5em;
    }
  }

  @media (max-width: 720px) {
    #menu-toggle {
      display: block;
    }

    .internal-links {
      position: absolute;
      top: 64px;
      left: 0;
      width: 100%;
      background: var(--bg-main);
      border-bottom: 1px solid rgb(var(--border-color));

      flex-direction: column;
      align-items: center;

      max-height: 0;
      overflow: hidden;

      transition: max-height 0.3s ease;
    }

    .internal-links.open {
      max-height: 300px;
    }

    nav a {
      width: 100%;
      text-align: center;
      padding: 1rem;
    }
  }
</style>
