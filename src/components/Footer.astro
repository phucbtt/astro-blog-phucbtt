---
const today = new Date();
---

<footer>
  <p>
    © {today.getFullYear()} PHUCBTT. All rights reserved.
  </p>

  <div class="social-links">
    <a href="https://github.com/phucbtt" target="_blank" aria-label="GitHub">
      GitHub
    </a>

    <a
      href="https://www.linkedin.com/in/bttp/"
      target="_blank"
      aria-label="LinkedIn"
    >
      LinkedIn
    </a>

    <a href="mailto:bt.thanhphuc@gmail.com" aria-label="Email"> Email </a>
  </div>
</footer>

<style>
  footer {
    padding: 2.5em 1em;
    background: var(--bg-soft);
    color: rgb(var(--gray));
    text-align: center;
    border-top: 1px solid rgb(var(--border-color));
    transition:
      background 0.3s ease,
      color 0.3s ease;
  }

  footer p {
    margin: 0;
    font-size: 0.9rem;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
    font-size: 0.9rem;
  }

  .social-links a {
    text-decoration: none;
    color: rgb(var(--gray));
    transition: color 0.2s ease;
  }

  .social-links a:hover {
    color: var(--accent);
  }
</style>
