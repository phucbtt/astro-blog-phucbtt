---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main class="container">
			<section class="hero">
				<h1>Hi, I'm Phuc</h1>
				<p class="subtitle">
					IT Helpdesk Professional focused on system reliability,
					user support, and continuous improvement.
				</p>

				<div class="cta">
					<a href="/about" class="primary-btn">About Me</a>
					<a href="/blog" class="secondary-btn">Read Blog</a>
				</div>
			</section>

			<section class="about-preview">
				<h2>Professional Focus</h2>
				<p>
					I specialize in troubleshooting, system stability, and operational efficiency.
					My goal is to reduce downtime, improve workflows, and contribute to a
					more reliable IT infrastructure.
				</p>
			</section>

			<section class="skills">
				<h2>Core Skills</h2>
				<ul>
					<li>Windows Administration</li>
					<li>Technical Troubleshooting</li>
					<li>Networking Fundamentals</li>
					<li>PowerShell / Bash (Learning)</li>
					<li>User & Access Management</li>
				</ul>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	.container {
		max-width: 900px;
		margin: auto;
		padding: 2rem 1.5rem;
	}

	.hero {
		text-align: center;
		padding: 4rem 0;
	}

	.hero h1 {
		font-size: 2.8rem;
		margin-bottom: 1rem;
	}

	.subtitle {
		font-size: 1.2rem;
		color: #555;
		margin-bottom: 2rem;
	}

	.cta {
		display: flex;
		justify-content: center;
		gap: 1rem;
	}

	.primary-btn {
		background: var(--accent);
		color: white;
		padding: 0.8rem 1.5rem;
		border-radius: 6px;
		text-decoration: none;
	}

	.secondary-btn {
		border: 1px solid var(--accent);
		padding: 0.8rem 1.5rem;
		border-radius: 6px;
		text-decoration: none;
		color: var(--accent);
	}

	section {
		margin-top: 3rem;
	}

	.skills ul {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 0.5rem;
		padding-left: 1rem;
	}
</style>