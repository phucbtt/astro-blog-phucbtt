---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

type ExperienceItem = {
  company: string;
  location: string;
  roles: string[];
};

type EducationItem = {
  school: string;
  degree: string;
  period: string;
};

const experienceItems: ExperienceItem[] = [
  {
    company: "JOYBIT",
    location: "Yen Hoa Ward, Hanoi",
    roles: ["IT Helpdesk - March 2026 to Present"],
  },
  {
    company: "AIWORKX Vietnam",
    location: "Hoang Mai District, Hanoi",
    roles: [
      "Data Annotator - March 2026 to Present",
      "Data Annotation and Labeling - August 2024 to February 2025",
    ],
  },
  {
    company: "SanAn Corporation Vietnam",
    location: "Cau Giay District, Hanoi",
    roles: [
      "IT Helpdesk - March 2026 to Present",
      "IT Infrastructure Engineer - January 2026 to March 2026",
      "IT Helpdesk - February 2025 to February 2026",
    ],
  },
  {
    company: "Vietnam College of Industry and Trade",
    location: "Hanoi, Vietnam",
    roles: ["IT Technical Support - February 2024 to July 2024"],
  },
];

const skillItems: string[] = [
  "System Administration",
  "Infrastructure Operations",
  "IT Helpdesk",
  "Technical Support",
  "Operational Troubleshooting",
  "Environment Support",
  "n8n",
  "GitLab",
];

const educationItems: EducationItem[] = [
  {
    school: "University of Transport Technology",
    degree: "Bachelor's Degree in Information Technology",
    period: "September 2025",
  },
  {
    school: "Vietnam College of Industry and Trade",
    degree: "Associate Degree in Computer Science",
    period: "2021 to 2023",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>

  <body>
    <Header />

    <main class="container portfolio-page">
      <section class="hero-card">
        <div class="hero-media">
          <img src="/avatar.jpg" alt="Phuc Bui" class="avatar" />

          <div class="social">
            <a
              href="https://github.com/phucbtt"
              target="_blank"
              rel="noreferrer"
              aria-label="GitHub"
            >
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.55 0-.27-.01-1.16-.02-2.1-3.2.7-3.88-1.54-3.88-1.54-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.76.4-1.27.73-1.56-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.3 1.19-3.11-.12-.3-.52-1.52.11-3.17 0 0 .97-.31 3.18 1.19a11.07 11.07 0 012.9-.39 11.1 11.1 0 012.9.39c2.2-1.5 3.17-1.19 3.17-1.19.64 1.65.24 2.87.12 3.17.74.81 1.19 1.85 1.19 3.11 0 4.43-2.69 5.4-5.26 5.69.41.35.77 1.04.77 2.1 0 1.52-.01 2.75-.01 3.12 0 .3.21.66.8.55A11.51 11.51 0 0023.5 12C23.5 5.65 18.35.5 12 .5z"
                ></path>
              </svg>
            </a>

            <a
              href="https://www.linkedin.com/in/bttp/"
              target="_blank"
              rel="noreferrer"
              aria-label="LinkedIn"
            >
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M4.98 3.5C4.98 4.88 3.86 6 2.49 6S0 4.88 0 3.5 1.12 1 2.49 1s2.49 1.12 2.49 2.5zM.22 8.5h4.54V24H.22V8.5zM8.29 8.5h4.35v2.11h.06c.61-1.16 2.11-2.39 4.34-2.39 4.64 0 5.5 3.05 5.5 7.02V24h-4.54v-7.64c0-1.82-.03-4.16-2.54-4.16-2.55 0-2.94 1.99-2.94 4.03V24H8.29V8.5z"
                ></path>
              </svg>
            </a>
          </div>
        </div>

        <div class="hero-copy">
          <p class="eyebrow">Nam Tu Liem, Hanoi, Vietnam</p>
          <h1>Phuc Bui</h1>
          <p class="subtitle">DevOps Engineer | System Administrator | IT Helpdesk</p>

          <p class="intro">
            IT professional with hands-on experience in helpdesk support,
            infrastructure operations, and system administration. I am building
            toward DevOps-focused work through practical experience in system
            reliability, operational troubleshooting, environment support, and
            day-to-day infrastructure execution.
          </p>

          <div class="hero-highlights">
            <div class="highlight-card">
              <span class="highlight-label">Focus</span>
              <strong>System reliability and infrastructure support</strong>
            </div>
            <div class="highlight-card">
              <span class="highlight-label">Direction</span>
              <strong>DevOps-oriented operations and automation</strong>
            </div>
            <div class="highlight-card">
              <span class="highlight-label">Strength</span>
              <strong>Practical support with strong operational discipline</strong>
            </div>
          </div>

          <div class="cta">
            <a href="/about" class="primary-btn">About Me</a>
            <a href="/blog" class="secondary-btn">Read Blog</a>
          </div>
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <h2>Professional Experience</h2>
          <p>Roles across support, infrastructure, and operational environments.</p>
        </div>

        <div class="experience-list">
          {experienceItems.map((item: ExperienceItem) => (
            <article class="info-card job-card">
              <div class="card-head">
                <h3>{item.company}</h3>
                <p class="company">{item.location}</p>
              </div>

              <ul class="role-list">
                {item.roles.map((role: string) => <li>{role}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <h2>Core Skills</h2>
          <p>Technical areas I work with most often in day-to-day operations.</p>
        </div>

        <div class="skills-grid">
          {skillItems.map((skill: string) => <div class="skill-card">{skill}</div>)}
        </div>
      </section>

      <section class="section-block split-layout">
        <div>
          <div class="section-heading">
            <h2>Certification</h2>
            <p>Current credential supporting my infrastructure background.</p>
          </div>

          <div class="info-card cert-card">
            <h3>OCNA</h3>
            <p>Omada Certified Network Administrator</p>
          </div>
        </div>

        <div>
          <div class="section-heading">
            <h2>Education</h2>
            <p>Academic background aligned with IT operations and system work.</p>
          </div>

          <div class="education-list">
            {educationItems.map((item: EducationItem) => (
              <article class="info-card edu-card">
                <h3>{item.school}</h3>
                <p>{item.degree}</p>
                <p class="edu-period">{item.period}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .portfolio-page {
    display: grid;
    gap: 2rem;
    padding-block: 2.5rem 4rem;
  }

  .hero-card,
  .section-block {
    border: 1px solid rgb(var(--border-color));
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(240, 253, 244, 0.8) 0%, rgba(255, 255, 255, 0.98) 100%);
    box-shadow: var(--box-shadow);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease,
      background 0.25s ease;
  }

  .hero-card {
    display: grid;
    grid-template-columns: minmax(220px, 280px) minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
    padding: 2rem;
  }

  .hero-media {
    display: grid;
    justify-items: center;
    align-content: start;
    gap: 1.25rem;
  }

  .avatar {
    width: clamp(140px, 18vw, 190px);
    height: clamp(140px, 18vw, 190px);
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--accent);
    box-shadow: var(--box-shadow);
  }

  .hero-copy {
    min-width: 0;
  }

  .eyebrow {
    margin: 0 0 0.6rem;
    color: rgb(var(--gray));
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-copy h1 {
    margin-bottom: 0.65rem;
    font-size: clamp(2.3rem, 5vw, 4rem);
  }

  .subtitle {
    margin: 0 0 1rem;
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    color: var(--accent);
    font-weight: 700;
  }

  .intro {
    max-width: 62ch;
    margin: 0;
    color: rgb(var(--gray));
  }

  .hero-highlights {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .highlight-card,
  .info-card,
  .skill-card {
    border: 1px solid rgb(var(--border-color));
    border-radius: 18px;
    background: var(--bg-main);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease,
      background 0.25s ease;
  }

  .highlight-card {
    padding: 1rem 1rem 1.1rem;
  }

  .highlight-label {
    display: block;
    margin-bottom: 0.45rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--gray));
  }

  .cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }

  .primary-btn,
  .secondary-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.85rem 1.5rem;
    border-radius: 999px;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }

  .primary-btn {
    background: var(--accent);
    color: white;
  }

  .secondary-btn {
    border: 2px solid var(--accent);
    color: var(--accent);
  }

  .section-block {
    padding: 1.6rem;
  }

  .section-heading {
    margin-bottom: 1.2rem;
  }

  .section-heading h2 {
    margin-bottom: 0.4rem;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
  }

  .section-heading p {
    margin: 0;
    color: rgb(var(--gray));
    font-size: 0.98rem;
  }

  .experience-list,
  .education-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    align-items: stretch;
  }

  .info-card {
    width: 100%;
    max-width: none;
    margin: 0;
    padding: 1.25rem;
    height: 100%;
    box-sizing: border-box;
  }

  .card-head {
    margin-bottom: 0.9rem;
  }

  .job-card h3,
  .edu-card h3,
  .cert-card h3 {
    margin-bottom: 0.3rem;
    font-size: 1.3rem;
  }

  .company,
  .edu-period {
    margin: 0;
    color: rgb(var(--gray));
    font-size: 0.95rem;
  }

  .role-list {
    margin: 0;
    padding-left: 1.2rem;
  }

  .role-list li + li {
    margin-top: 0.55rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 1rem;
  }

  .skill-card {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 92px;
    padding: 1rem;
    text-align: center;
    font-weight: 700;
    background: var(--bg-soft);
  }

  .hero-card:hover,
  .section-block:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow:
      0 10px 30px rgba(22, 101, 52, 0.12),
      0 18px 48px rgba(22, 101, 52, 0.08);
  }

  .highlight-card:hover,
  .info-card:hover,
  .skill-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: var(--box-shadow);
  }

  .primary-btn:hover,
  .secondary-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--box-shadow);
  }

  .primary-btn:hover {
    background: var(--accent-dark);
    color: white;
  }

  .secondary-btn:hover {
    background: var(--accent);
    color: white;
  }

  .split-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .split-layout > div {
    min-width: 0;
  }

  .cert-card p,
  .edu-card p {
    margin: 0;
  }

  .cert-card {
    height: auto;
    min-height: 0;
  }

  .edu-card .edu-period {
    margin-top: 0.75rem;
  }

  .social {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .social a {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: rgb(var(--gray-light));
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgb(var(--border-color));
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }

  .social svg {
    width: 20px;
    height: 20px;
  }

  .social a:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    background: var(--bg-soft);
    box-shadow: var(--box-shadow);
  }

  .portfolio-page article {
    max-width: none;
    margin: 0;
  }

  :root.dark .hero-card,
  :root.dark .section-block {
    background:
      linear-gradient(180deg, rgba(30, 41, 59, 0.92) 0%, rgba(15, 23, 42, 0.98) 100%);
  }

  :root.dark .highlight-card,
  :root.dark .info-card {
    background: rgba(15, 23, 42, 0.9);
    border-color: rgb(var(--border-color));
  }

  :root.dark .skill-card {
    background:
      linear-gradient(180deg, rgba(30, 41, 59, 0.95) 0%, rgba(15, 23, 42, 0.95) 100%);
    color: rgb(var(--black));
  }

  :root.dark .social a {
    background: rgba(30, 41, 59, 0.95);
    color: rgb(var(--black));
  }

  :root.dark .secondary-btn {
    background: rgba(30, 41, 59, 0.65);
    color: rgb(var(--black));
    border-color: var(--accent);
  }

  :root.dark .primary-btn {
    color: rgb(15, 23, 42);
  }

  :root.dark .highlight-label,
  :root.dark .section-heading p,
  :root.dark .company,
  :root.dark .edu-period,
  :root.dark .intro,
  :root.dark .eyebrow {
    color: rgb(var(--gray));
  }

  :root.dark .skill-card:hover,
  :root.dark .highlight-card:hover,
  :root.dark .info-card:hover,
  :root.dark .hero-card:hover,
  :root.dark .section-block:hover,
  :root.dark .social a:hover,
  :root.dark .secondary-btn:hover {
    box-shadow: var(--box-shadow);
    border-color: var(--accent);
  }

  :root.dark .secondary-btn:hover {
    background: var(--accent);
    color: rgb(15, 23, 42);
  }

  @media (max-width: 900px) {
    .hero-card,
    .split-layout {
      grid-template-columns: 1fr;
    }

    .hero-card {
      padding: 1.5rem;
    }

    .hero-highlights {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .portfolio-page {
      gap: 1.25rem;
      padding-block: 1.5rem 3rem;
    }

    .section-block,
    .hero-card {
      border-radius: 20px;
      padding: 1.2rem;
    }

    .experience-list,
    .education-list,
    .skills-grid {
      grid-template-columns: 1fr;
    }

    .cta {
      flex-direction: column;
    }

    .primary-btn,
    .secondary-btn {
      width: 100%;
    }
  }
</style>
