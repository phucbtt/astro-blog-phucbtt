---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>

  <body>
    <Header />

    <main class="container">
      <!-- HERO -->
      <section class="hero">
        <img src="/avatar.jpg" alt="Phuc Bui" class="avatar" />

        <div class="social">
          <a
            href="https://github.com/phucbtt"
            target="_blank"
            aria-label="GitHub"
          >
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91..."
              ></path>
            </svg>
          </a>

          <a
            href="https://www.linkedin.com/in/bttp/"
            target="_blank"
            aria-label="LinkedIn"
          >
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M4.98 3.5C4.98 4.88 3.86 6 2.49 6S0 4.88 0 3.5..."
              ></path>
            </svg>
          </a>
        </div>

        <h1>Phuc Bui</h1>

        <p class="subtitle">
          IT Helpdesk | IT Infrastructure | Technical Support
        </p>

        <p class="intro">
          IT professional based in Hanoi with hands-on experience in helpdesk
          support, infrastructure operations, and system troubleshooting.
          Focused on maintaining stable IT environments and improving
          operational efficiency.
        </p>

        <div class="cta">
          <a href="/about" class="primary-btn">About Me</a>
          <a href="/blog" class="secondary-btn">Read Blog</a>
        </div>
      </section>

      <!-- EXPERIENCE -->
      <section class="experience">
        <h2>Professional Experience</h2>

        <div class="job">
          <h3>IT Infrastructure Engineer</h3>
          <p class="company">SanAn Corporation Vietnam · Jan 2026 – Mar 2026</p>
          <p>
            Supported IT infrastructure operations, system monitoring, and
            ensured stability across internal technical environments.
          </p>
        </div>

        <div class="job">
          <h3>IT Helpdesk | Technical Support</h3>
          <p class="company">SanAn Corporation Vietnam · Feb 2025 – Feb 2026</p>
          <p>
            Provided technical support for end users, resolved hardware and
            software issues, managed user accounts, and maintained system
            reliability.
          </p>
        </div>

        <div class="job">
          <h3>IT Technical Support</h3>
          <p class="company">
            Vietnam College of Industry and Commerce · Feb 2024 – Jul 2024
          </p>
          <p>
            Handled on-site technical support, device configuration, and network
            troubleshooting within educational environments.
          </p>
        </div>
      </section>

      <!-- SKILLS -->
      <section class="skills">
        <h2>Core Skills</h2>

        <div class="skills-grid">
          <div class="skill-card">System Monitoring</div>
          <div class="skill-card">Technical Troubleshooting</div>
          <div class="skill-card">Linux</div>
          <div class="skill-card">Windows Administration</div>
          <div class="skill-card">User & Access Management</div>
          <div class="skill-card">Networking Fundamentals</div>
        </div>
      </section>

      <!-- CERTIFICATION -->
      <section class="certification">
        <h2>Certification</h2>
        <p class="cert-card">OCNA – Omada Certified Network Administrator</p>
      </section>

      <!-- EDUCATION -->
      <section class="education">
        <h2>Education</h2>

        <div class="edu-item">
          Bachelor of Information Technology – University of Transport
          Technology (2025)
        </div>

        <div class="edu-item">
          Associate Degree in Computer Science – Vietnam College of Industry and
          Commerce (2021–2023)
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  /* ===== CONTAINER ===== */

  .container {
    max-width: 1000px;
    margin: auto;
    padding: 2.5rem 1.5rem;
  }

  /* ===== SECTION SPACING ===== */

  section {
    margin-top: 4rem;
  }

  /* ===== HERO ===== */

  .hero {
    text-align: center;
  }

  .avatar {
    width: clamp(110px, 15vw, 150px);
    height: clamp(110px, 15vw, 150px);
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--accent);
    box-shadow: var(--box-shadow);
    margin-bottom: 1.4rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 1.2rem;
  }

  .intro {
    max-width: 640px;
    margin: auto;
    color: rgb(var(--gray));
    margin-bottom: 2rem;
  }

  /* ===== CTA ===== */

  .cta {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .primary-btn {
    background: var(--accent);
    color: white;
    padding: 0.9rem 1.6rem;
    border-radius: 8px;
    font-weight: 600;
  }

  .secondary-btn {
    border: 2px solid var(--accent);
    padding: 0.9rem 1.6rem;
    border-radius: 8px;
    color: var(--accent);
    font-weight: 600;
  }

  /* ===== EXPERIENCE ===== */

  .job {
    margin-top: 1.5rem;
    padding: 1.4rem;
    border-left: 4px solid var(--accent);
    background: rgb(var(--gray-light));
    border-radius: 12px;
  }

  .company {
    font-size: 0.9rem;
    color: rgb(var(--gray));
  }

  /* ===== SKILLS ===== */

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.2rem;
    margin-top: 1.6rem;
  }

  .skill-card {
    background: rgb(var(--gray-light));
    padding: 1.2rem;
    border-radius: 12px;
    text-align: center;
    font-weight: 600;
    border: 1px solid rgba(var(--gray), 0.2);
  }

  /* ===== CERTIFICATION ===== */

  .cert-card {
    margin-top: 1rem;
    padding: 1.2rem;
    background: rgb(var(--gray-light));
    border-left: 4px solid var(--accent);
    border-radius: 10px;
  }

  /* ===== EDUCATION ===== */

  .edu-item {
    margin-top: 1rem;
    padding: 1rem 1.2rem;
    background: rgb(var(--gray-light));
    border-radius: 10px;
    border-left: 3px solid var(--accent);
  }

  /* ===== SOCIAL ===== */

  .social {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.3rem;
  }

  .social a {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgb(var(--gray-light));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .social svg {
    width: 20px;
    height: 20px;
  }

  /* ===== MOBILE ===== */

  @media (max-width: 768px) {
    section {
      margin-top: 3rem;
    }

    .cta {
      flex-direction: column;
      align-items: center;
    }

    .primary-btn,
    .secondary-btn {
      width: 220px;
      text-align: center;
    }
  }
</style>
